# Google Cloud / Cloud Run Job
PROJECT_ID=dev-aisalad-499012
REGION=us-central1
JOB_NAME=leetcode-solver-job
AR_REPO=leetcode-solver
RUNNER_SA_NAME=leetcode-solver-runner
RUN_ROOT=/tmp/leetcode-runs
REPOSITORY=leetcode-solver
IMAGE_NAME=leetcode-solver
SERVICE_ACCOUNT_NAME=leetcode-solver-runner

# Where structured run folders are uploaded after the Cloud Run Job finishes.
BUCKET_NAME=dev-aisalad-499012-leetcode-solver-runs
OUTPUT_GCS_URI=gs://dev-aisalad-499012-leetcode-solver-runs

# LeetCode auth state saved by: python login.py lc-auth.json
LC_AUTH_JSON_FILE=lc-auth.json
LC_AUTH_SECRET_NAME=leetcode-lc-auth-json
LC_LANG=python3
LC_LLM=true
LC_HEADLESS=true
LC_DRY_RUN=false
LC_VERBOSE_RESULT=false
LC_TIMEOUT_MS=120000

# MongoDB Atlas persistence. Prefer setting MONGODB_URI_FILE in shared envs.
MONGODB_URI=<connection_id>
MONGODB_URI_FILE=
MONGODB_URI_SECRET_NAME=leetcode-mongodb-uri
MONGODB_DB=leetcode_solver
MONGODB_COLLECTION=solution_packs

# Optional: let deploy_leetcode_job.sh create/configure an Atlas M0 cluster with the Atlas CLI.
ATLAS_SETUP=false
ATLAS_CLUSTER_NAME=leetcode-solver
ATLAS_PROVIDER=GCP
ATLAS_REGION=CENTRAL_US
ATLAS_TIER=M0
ATLAS_DB_USERNAME=leetcode_solver
ATLAS_DB_PASSWORD=
ATLAS_PROJECT_ID=
ATLAS_ACCESS_LIST_IP=

# Optional Overmind tracing
OVERMIND_API_KEY=
OVERMIND_API_KEY_FILE=
OVERMIND_API_KEY_SECRET_NAME=leetcode-overmind-api-key
OVERMIND_SERVICE_NAME=leetcode-solver
OVERMIND_ENVIRONMENT=production
OVERMIND_ENABLED=true

# Cloud Run Job resources
JOB_MEMORY=2Gi
JOB_CPU=2
TASK_TIMEOUT=1800s

# ---------------- Gemini / Vertex AI ----------------
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=dev-aisalad-499012
GOOGLE_CLOUD_LOCATION=global
VERTEX_LOCATION=global
LEETCODE_CODE_MODEL=gemini-2.5-pro
LEETCODE_RATIONALE_MODEL=gemini-2.5-pro

# Local API-key mode for experiments only:
# GOOGLE_GENAI_USE_VERTEXAI=False
# GEMINI_API_KEY=your-api-key
